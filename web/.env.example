# Copy to .env.local for development (gitignored). In CI these are written to
# .env.production from GitHub Secrets/Variables. Every VITE_* var is embedded in
# the client bundle — same exposure as the current site. Firebase web config is
# public by design; the real protection is Firestore security rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_APP_SITE_TITLE=Hope Raider
VITE_APP_ADMIN_UIDS=
VITE_APP_DISCORD_INVITE_URL=https://discord.gg/H2MtWtBGGC

VITE_WCL_CLIENT_ID=
VITE_WCL_CLIENT_SECRET=
VITE_DISCORD_WEBHOOK_URL=
